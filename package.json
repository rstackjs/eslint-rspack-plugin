{
  "name": "eslint-rspack-plugin",
  "version": "4.4.1",
  "description": "A ESLint plugin for rspack",
  "license": "MIT",
  "repository": "https://github.com/rstackjs/eslint-rspack-plugin",
  "author": "Ricardo Gobbo de Souza <ricardogobbosouza@yahoo.com.br>",
  "homepage": "https://github.com/rstackjs/eslint-rspack-plugin",
  "bugs": "https://github.com/rstackjs/eslint-rspack-plugin/issues",
  "type": "module",
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/webpack"
  },
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">= 20.19.0"
  },
  "scripts": {
    "start": "rslib -w",
    "build": "rslib",
    "security": "npm audit",
    "lint:prettier": "prettier -w --list-different .",
    "lint:js": "eslint --cache .",
    "lint:spelling": "cspell \"**/*.*\"",
    "lint:types": "tsc --pretty --noEmit",
    "lint": "npm-run-all -l -p \"lint:**\"",
    "fix:js": "pnpm run lint:js -- --fix",
    "fix:prettier": "pnpm run lint:prettier -- --write",
    "fix": "npm-run-all -l fix:js fix:prettier",
    "test:watch": "rstest --watch",
    "pretest": "pnpm run lint",
    "test": "rstest",
    "prepare": "pnpm run build",
    "bump": "npx bumpp"
  },
  "packageManager": "pnpm@10.17.1",
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@rspack/core": "^1.0.8 || ^2.0.0",
    "eslint": "^9.0.0 || ^10.0.0"
  },
  "peerDependenciesMeta": {
    "@rspack/core": {
      "optional": true
    }
  },
  "dependencies": {
    "@types/eslint": "^9.6.1",
    "micromatch": "^4.0.8",
    "normalize-path": "^3.0.0",
    "tinyglobby": "^0.2.15"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rslib/core": "^0.21.4",
    "@rspack/core": "^2.0.2",
    "@rstest/core": "^0.9.10",
    "@types/fs-extra": "^11.0.4",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^20.14.9",
    "@types/normalize-path": "^3.0.2",
    "chokidar": "^3.6.0",
    "cspell": "^8.13.1",
    "del": "^7.1.0",
    "del-cli": "^5.1.0",
    "eslint": "^9.39.4",
    "fs-extra": "^11.2.0",
    "globals": "^16.5.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.8",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "keywords": [
    "eslint",
    "lint",
    "linter",
    "plugin",
    "rspack"
  ]
}
